  "devDependencies": {
    "@types/github-slugger": "^1.3.0",
    "@types/jest": "^27.0.3",
    "@types/node": "^16.11.11",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "@types/react-transition-group": "^4.4.4",
    "@types/recharts": "^1.8.16",
    "@types/webpack-env": "^1.16.3",
    "eslint": "^7.11.0",
    "eslint-config-airbnb": "^19.0.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-flowtype": "^7.0.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jest": "^25.3.0",
    "eslint-plugin-jsx-a11y": "^6.3.1",
    "eslint-plugin-react": "^7.21.3",
    "eslint-plugin-react-hooks": "^4.3.0",
    "prettier": "^2.1.2",
    "sass": "^1.44.0"
  },
  "scripts": {
    "start": "NODE_OPTIONS=--openssl-legacy-provider react-scripts start",
    "build": "CI=false NODE_OPTIONS=--openssl-legacy-provider env-cmd -f .env.production react-scripts build",
    "postbuild": "cp build/index.html build/404.html",
    "test": "react-scripts test --passWithNoTests",
    "lint": "npm run lint:ts",
    "lint:ts": "eslint src/**/*.ts src/**/*.tsx",
    "translations:export": "npx ts-node -P scripts/tsconfig.json scripts/export-translations.ts",
    "translations:import": "npx ts-node -P scripts/tsconfig.json scripts/import-translations.ts"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version",
      "not dead"
    ]
  },
  "homepage": "./",
  "resolutions": {
    "babel-preset-react-app": "10.0.0"
  }
}

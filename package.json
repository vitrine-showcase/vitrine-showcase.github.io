{
  "name": "vitrine-showcase",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=16.0.0",
    "npm": "⚠️please-use-yarn",
    "yarn": ">= 1.15.0"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^5.11.4",
    "@testing-library/react": "^12.1.2",
    "@testing-library/user-event": "^13.5.0",

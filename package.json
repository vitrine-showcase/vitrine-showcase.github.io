    "react-app-polyfill": "^2.0.0",
    "react-dom": "^17.0.2",
    "react-i18next": "^11.14.3",
    "react-markdown": "^5.0.3",
    "react-refresh": "^0.18.0",
    "react-router": "^6.2.1",
    "react-router-dom": "^6.2.1",
    "react-scripts": "4.0.3",
    "react-transition-group": "^4.4.2",
    "recharts": "^1.8.5",
    "remark-directive": "^1.0.1",
